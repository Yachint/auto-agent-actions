WEBHOOK_DOMAIN=reviews.example.com
ACME_EMAIL=owner@example.com
GITHUB_APP_ID=0
GITHUB_ALLOWED_REPOSITORIES=owner/repository

# Pin these to versions tested before deployment. Production should prefer
# immutable image digests after the first successful validation.
CODEX_CLI_VERSION=0.0.0-replace-me
REDIS_IMAGE=redis:7.4-alpine
CADDY_IMAGE=caddy:2.10-alpine

# Host paths. Keep secret files mode 0600 and the Codex directory mode 0700.
GITHUB_APP_PRIVATE_KEY_HOST_FILE=/opt/auto-agent-actions/secrets/github-app.pem
GITHUB_WEBHOOK_SECRET_HOST_FILE=/opt/auto-agent-actions/secrets/github-webhook-secret
READ_TOKEN_BROKER_SECRET_HOST_FILE=/opt/auto-agent-actions/secrets/read-token-broker-secret
CODEX_CREDENTIALS_DIR=/opt/auto-agent-actions/codex-home

LOG_LEVEL=info
REVIEW_QUEUE_NAME=pull-request-reviews
PUBLICATION_QUEUE_NAME=pull-request-publications
REVIEW_QUEUE_DEBOUNCE_MS=1000
REVIEW_WORKER_CONCURRENCY=1
PUBLISHER_WORKER_CONCURRENCY=5
REVIEW_MINIMUM_CONFIDENCE=0.8
REVIEW_MAXIMUM_INLINE_COMMENTS=20
RECONCILIATION_INTERVAL_MS=900000
ABANDONED_WORKTREE_AGE_MS=86400000
CODEX_MODEL=gpt-5.6-sol
CODEX_REASONING_EFFORT=high
CODEX_TIMEOUT_MS=600000
ANALYSIS_MEMORY_LIMIT=4g
ANALYSIS_CPU_LIMIT=2.0
