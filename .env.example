HOST=127.0.0.1
PORT=3000
LOG_LEVEL=info

# Added in later milestones. Never commit their values.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_FILE=/run/secrets/github-app-private-key.pem
GITHUB_WEBHOOK_SECRET=
# Alternative to GITHUB_WEBHOOK_SECRET; do not set both.
GITHUB_WEBHOOK_SECRET_FILE=
GITHUB_ALLOWED_REPOSITORIES=owner/repository

# Optional API-key alternative. The selected first-release path reuses a
# trusted VPS login created with `codex login` instead.
CODEX_API_KEY=
CODEX_MODEL=gpt-5.6-sol
CODEX_REASONING_EFFORT=high
CODEX_TIMEOUT_MS=600000
CODEX_BINARY=codex
REVIEW_DATA_DIR=.review-data
ABANDONED_WORKTREE_AGE_MS=86400000

# Required when the durable webhook queue is enabled.
REDIS_URL=redis://127.0.0.1:6379
REVIEW_QUEUE_NAME=pull-request-reviews
PUBLICATION_QUEUE_NAME=pull-request-publications
REVIEW_QUEUE_DEBOUNCE_MS=1000
REVIEW_WORKER_CONCURRENCY=1
PUBLISHER_WORKER_CONCURRENCY=5
REVIEW_MINIMUM_CONFIDENCE=0.8
REVIEW_MAXIMUM_INLINE_COMMENTS=20
RECONCILIATION_INTERVAL_MS=900000

# Unix-socket token broker shared by publisher and analysis containers.
READ_TOKEN_BROKER_SOCKET=/run/auto-agent-actions/read-token-broker.sock
READ_TOKEN_BROKER_SECRET=
# Alternative to READ_TOKEN_BROKER_SECRET; do not set both.
READ_TOKEN_BROKER_SECRET_FILE=
