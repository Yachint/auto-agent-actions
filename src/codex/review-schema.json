{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://auto-agent-actions.local/schemas/review-output.json",
  "title": "Codex pull request review output",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "findings", "summary", "blocked_reason"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["completed", "blocked"],
      "description": "Use completed only after the exact diff was inspected; otherwise use blocked."
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "title",
          "body",
          "priority",
          "confidence",
          "path",
          "start_line",
          "end_line"
        ],
        "properties": {
          "title": { "type": "string", "minLength": 1 },
          "body": { "type": "string", "minLength": 1 },
          "priority": {
            "type": "integer",
            "minimum": 0,
            "maximum": 3,
            "description": "P0 is critical and P3 is low priority."
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "path": { "type": "string", "minLength": 1 },
          "start_line": { "type": "integer", "minimum": 1 },
          "end_line": { "type": "integer", "minimum": 1 }
        }
      }
    },
    "summary": { "type": "string", "minLength": 1, "maxLength": 4000 },
    "blocked_reason": {
      "type": ["string", "null"],
      "minLength": 1,
      "maxLength": 1000,
      "description": "Null for completed reviews; a concise reason for blocked reviews."
    }
  }
}
